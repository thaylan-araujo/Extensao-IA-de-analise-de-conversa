# --- Extensão Chrome (apps/extension) ---
# Prefixo WXT_ expõe a variável ao bundle via import.meta.env (WXT/Vite).
# WXT_SUPABASE_URL: mesmo valor de NEXT_PUBLIC_SUPABASE_URL
WXT_SUPABASE_URL=
# WXT_SUPABASE_ANON_KEY: mesmo valor de NEXT_PUBLIC_SUPABASE_ANON_KEY (anon key é pública por design; RLS protege)
WXT_SUPABASE_ANON_KEY=
# WXT_WEB_APP_URL: URL do painel web da Fase 1 (usada pelo link "Esqueci minha senha" do painel)
WXT_WEB_APP_URL=
